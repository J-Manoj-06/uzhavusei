rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read: if isSelf(userId) || (request.query.limit <= 1 && request.query.filters[0].field == 'phoneNumber');
      allow create: if isSelf(userId);
      allow update: if isSelf(userId);
      allow delete: if false;
    }

    // Calendar page source collection.
    match /machineries/{machineryId} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /equipments/{equipmentId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /equipment/{equipmentId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.owner_user_id == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.owner_user_id == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'savedBy'])
      );
      allow delete: if signedIn() && resource.data.owner_user_id == request.auth.uid;
    }

    match /marketplace_surplus/{surplusId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /farm_surplus_exchange/{exchangeId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /bookings/{bookingId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;

      // Needed by calendar to load already-booked dates per machinery.
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.ownerId == request.auth.uid ||
        resource.data.machineryId is string
      );

      allow update: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.ownerId == request.auth.uid
      );
      allow delete: if false;
    }

    match /shared_links_analytics/{docId} {
      allow read, write: if signedIn();
    }
  }
}
